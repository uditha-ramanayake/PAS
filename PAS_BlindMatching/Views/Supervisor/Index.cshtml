﻿@model IEnumerable<PAS_BlindMatching.Models.ProjectViewModel>

@{
    ViewData["Title"] = "Blind Review Dashboard";
    var supervisorArea = ViewBag.SupervisorArea as string;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-search me-2"></i>Blind Review Dashboard
            </h2>
            <p class="text-muted mb-0">Student identities remain hidden until you confirm a match.</p>
        </div>
        <a asp-action="MyMatches" class="btn btn-outline-dark btn-sm">
            <i class="bi bi-people me-1"></i>My Matches
        </a>
    </div>

    @* Research area filter banner *@
    @if (!string.IsNullOrWhiteSpace(supervisorArea))
    {
        <div class="alert alert-info border-0 d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-funnel-fill fs-5"></i>
            <div>
                <strong>Filtered by your research area:</strong>
                <span class="badge bg-primary ms-2 fs-6">@supervisorArea</span>
                <span class="ms-2 text-muted small">— showing only projects that match your expertise.</span>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning border-0 d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>
                <strong>No research area set on your profile.</strong>
                <span class="ms-2 text-muted small">All pending proposals are shown. Consider updating your profile to filter by area.</span>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <i class="bi bi-folder-x text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">No proposals available</h4>
            <p class="text-muted">
                @if (!string.IsNullOrWhiteSpace(supervisorArea))
                {
                    <span>There are no pending proposals matching <strong>@supervisorArea</strong> right now.</span>
                }
                else
                {
                    <span>There are no pending proposals at the moment.</span>
                }
            </p>
            <a asp-action="MyMatches" class="btn btn-outline-primary mt-2">View My Matches</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-dark text-white py-3">
                            <h5 class="card-title mb-0 text-truncate" title="@project.Title">@project.Title</h5>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-info text-dark mb-2 align-self-start">
                                <i class="bi bi-tag me-1"></i>@project.ResearchArea
                            </span>
                            <p class="card-text text-muted small flex-grow-1" style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical;">
                                @project.Abstract
                            </p>
                            <hr class="my-2" />
                            <p class="small mb-2"><strong>Tech Stack:</strong> @project.TechStack</p>
                            <p class="small text-danger mb-3">
                                <i class="bi bi-eye-slash me-1"></i><strong>Identity:</strong> @project.StudentName
                            </p>

                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm flex-fill"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modal-@project.Id">
                                    <i class="bi bi-eye me-1"></i>Full Details
                                </button>
                                <form asp-action="SelectProject" method="post" class="flex-fill">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@project.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        <i class="bi bi-check2-circle me-1"></i>Confirm Match
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    @* Full Details Modal *@
                    <div class="modal fade" id="modal-@project.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content">
                                <div class="modal-header bg-dark text-white">
                                    <h5 class="modal-title">@project.Title</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-6">
                                            <p class="mb-1 text-muted small fw-semibold">RESEARCH AREA</p>
                                            <span class="badge bg-info text-dark">@project.ResearchArea</span>
                                        </div>
                                        <div class="col-sm-6">
                                            <p class="mb-1 text-muted small fw-semibold">TECH STACK</p>
                                            <p class="mb-0">@project.TechStack</p>
                                        </div>
                                    </div>
                                    <hr />
                                    <p class="mb-1 text-muted small fw-semibold">ABSTRACT</p>
                                    <p style="white-space: pre-wrap;">@project.Abstract</p>
                                    <hr />
                                    <p class="small text-danger mb-0">
                                        <i class="bi bi-eye-slash me-1"></i>
                                        Student identity will be revealed after you confirm the match.
                                    </p>
                                </div>
                                <div class="modal-footer">
                                    <form asp-action="SelectProject" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@project.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="bi bi-check2-circle me-1"></i>Confirm Match
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease;
    }
</style>
