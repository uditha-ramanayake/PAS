@model PAS_BlindMatching.Models.ProjectViewModel

@{
    ViewData["Title"] = "Edit Proposal";
    var researchAreas = ViewBag.ResearchAreas as List<string> ?? new List<string>();
    bool isGroup = ViewBag.IsGroup == true;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark py-4 text-center">
                    <i class="bi bi-pencil-square" style="font-size: 2.5rem;"></i>
                    <h3 class="mt-2 mb-0">Edit Proposal</h3>
                    <p class="text-dark-50 mb-0 small">
                        You can only edit proposals with <strong>Pending</strong> status.
                    </p>
                </div>

                <div class="card-body p-4">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Edit" asp-controller="Project" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Project Title <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="title" class="form-control" value="@Model.Title" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Abstract <span class="text-danger">*</span>
                            </label>
                            <textarea name="abstract" class="form-control" rows="5" required>@Model.Abstract</textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Tech Stack <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="techStack" class="form-control" value="@Model.TechStack" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Research Area
                                <span class="text-muted fw-normal small">(optional)</span>
                            </label>
                            <select name="researchArea" class="form-select">
                                <option value="">-- Select a research area --</option>
                                @foreach (var area in researchAreas)
                                {
                                    <option value="@area" selected="@(Model.ResearchArea == area)">@area</option>
                                }
                            </select>
                        </div>

                        @if (isGroup)
                        {
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-primary">
                                    <i class="bi bi-people-fill me-2"></i>Group Members
                                    <span class="text-danger">*</span>
                                </label>
                                <p class="text-muted small mb-2">Update group members below.</p>

                                <div id="membersContainer">
                                    @if (Model.GroupMembers != null && Model.GroupMembers.Any())
                                    {
                                        @foreach (var member in Model.GroupMembers)
                                        {
                                            <div class="member-row d-flex gap-2 mb-2 align-items-center">
                                                <input type="text" name="memberNames" class="form-control" placeholder="Member Name" value="@member.Name" required />
                                                <input type="text" name="memberIds" class="form-control" placeholder="User ID" value="@member.UserId" required />
                                                <button type="button" class="btn btn-outline-danger btn-sm remove-member" title="Remove">
                                                    <i class="bi bi-dash-circle"></i>
                                                </button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="member-row d-flex gap-2 mb-2 align-items-center">
                                            <input type="text" name="memberNames" class="form-control" placeholder="Member Name" required />
                                            <input type="text" name="memberIds" class="form-control" placeholder="User ID" required />
                                            <button type="button" class="btn btn-outline-danger btn-sm remove-member" title="Remove" style="display:none;">
                                                <i class="bi bi-dash-circle"></i>
                                            </button>
                                        </div>
                                    }
                                </div>

                                <button type="button" id="addMemberBtn" class="btn btn-outline-primary btn-sm mt-1">
                                    <i class="bi bi-plus-circle me-1"></i>Add Another Member
                                </button>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-fill py-2">
                                <i class="bi bi-save me-2"></i>Save Changes
                            </button>
                            <a asp-controller="Project" asp-action="MyProjects"
                               class="btn btn-outline-secondary flex-fill py-2">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isGroup)
{
    <script>
        document.getElementById('addMemberBtn')?.addEventListener('click', function () {
            const container = document.getElementById('membersContainer');
            const row = document.createElement('div');
            row.className = 'member-row d-flex gap-2 mb-2 align-items-center';
            row.innerHTML = `
                <input type="text" name="memberNames" class="form-control" placeholder="Member Name" required />
                <input type="text" name="memberIds" class="form-control" placeholder="User ID" required />
                <button type="button" class="btn btn-outline-danger btn-sm remove-member" title="Remove">
                    <i class="bi bi-dash-circle"></i>
                </button>`;
            container.appendChild(row);
            updateRemoveButtons();
        });

        document.getElementById('membersContainer')?.addEventListener('click', function (e) {
            if (e.target.closest('.remove-member')) {
                e.target.closest('.member-row').remove();
                updateRemoveButtons();
            }
        });

        function updateRemoveButtons() {
            const rows = document.querySelectorAll('.member-row');
            rows.forEach((row, i) => {
                const btn = row.querySelector('.remove-member');
                btn.style.display = rows.length > 1 ? 'inline-block' : 'none';
            });
        }

        updateRemoveButtons();
    </script>
}
